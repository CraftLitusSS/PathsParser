<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====================================================================
         MODUL KARTI (CARD)
         Arka plan: #1A1A1A, cerceve: #2A2A2A
         Hover => cerceve aninda Neon Sari (#CCFF00)
         ==================================================================== -->
    <Style x:Key="NeonCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Bg card brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border subtle brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="0" Opacity="0" ShadowDepth="0" Color="#CCFF00" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Kart hover davranisi icin trigger destegi:
         Kart'in icindeki en ust Border'a x:Name="CardBorder" verip
         asagidaki gibi kullan:
         
         <Border Style="{StaticResource NeonCard}" x:Name="CardBorder">
             ...
         </Border>
         
         NOT: WPF'de Border'da IsMouseOver trigger'i calisir.
         Asagidaki trigger'lar dogrudan Border'a eklenir.
    -->

    <!-- Ornek butonlu kart (bir Border icinde ContentControl ile) -->
    <Style x:Key="NeonCardInteractive" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Bg card brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border subtle brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Neon primary brush}" />
                <Setter Property="Background" Value="{StaticResource Bg cardHover brush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ====================================================================
         ISTATISTIK KARTI (sayi + etiket)
         Kullanimi:
         <Border Style="{StaticResource NeonStatCard}" Width="180" Height="100">
             <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                 <TextBlock Style="{StaticResource NeonStatNumber}" Text="1,234" />
                 <TextBlock Style="{StaticResource NeonStatLabel}" Text="Files Found" />
             </StackPanel>
         </Border>
         ==================================================================== -->
    <Style x:Key="NeonStatCard" TargetType="Border" BasedOn="{StaticResource NeonCardInteractive}">
        <Setter Property="Width" Value="180" />
        <Setter Property="Height" Value="100" />
    </Style>

    <Style x:Key="NeonStatNumber" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Text neon brush}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style x:Key="NeonStatLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Text secondary brush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- ====================================================================
         PROGRESS BAR
         ==================================================================== -->
    <Style x:Key="NeonProgressBar" TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource Bg medium brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border subtle brush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="6" />
        <Setter Property="Foreground" Value="{StaticResource Neon primary brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid MinHeight="{TemplateBinding Height}">
                        <Border x:Name="PART_Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                        <Border x:Name="PART_Indicator"
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left"
                                CornerRadius="3" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
